msgid "Press Shift + N to view notifications"
msgstr "Druk op Shift + N om meldingen te bekijken"

msgid "Sleep prevented by an active process"
msgstr "Slaapmodus verhinderd door een actief proces"

msgid "1 minute"
msgstr "1 minuut"

msgid "10 minutes"
msgstr "10 minuten"

msgid "15 minutes"
msgstr "15 minuten"

msgid "2 hours"
msgstr "2 uur"

