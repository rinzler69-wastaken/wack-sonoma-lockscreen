msgid "Upgrade to Pro"
msgstr "Opgrader till Pro"

msgid "Get a Sonoma-inspired GDM login screen layout and automatically synchronize your wallpapers from the active user session. To upgrade, run copied command in a terminal."
msgstr "Få et Sonoma-inspireret GDM-loginskærmslayout, og synkroniser automatisk dine tapeter fra den aktive brugersession. For at opgradere skal du køre den kopierede kommando i en terminal."

msgid "Copy upgrade command to clipboard"
msgstr "Kopier opgraderingskommando til udklipsholder"

msgid "Copied upgrade command to clipboard!"
msgstr "Opgraderingskommando kopieret til udklipsholder!"

msgid "Uninstall GDM Expansion"
msgstr "Afinstaller GDM-udvidelse"

msgid "Revert GDM login screen layout to GNOME Default. To uninstall, run copied command in a terminal."
msgstr "Gendan GDM-loginskærmslayout til GNOME-standard. For at afinstallere skal du køre den kopierede kommando i een terminal."

msgid "Copy uninstall command to clipboard"
msgstr "Kopier afinstalleringskommando til udklipsholder"

msgid "Copied uninstall command to clipboard!"
msgstr "Afinstalleringskommando kopieret til udklipsholder!"

