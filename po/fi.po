msgstr "Avaa Saweria"

msgid "Open on GitHub"
msgstr "Avaa GitHubissa"

msgid "Press Escape on the lock screen to sleep display (or suspend)"
msgstr "Paina Esc-näppäintä lukitusnäytöllä sammuttaaksesi näytön (tai siirtyäksesi valmiustilaan)"

msgid "Prevent the screen from immediately turning off when locked. The screen will still turn off after the normal timeout duration set in system settings."
msgstr "Estää näytön sammumisen heti, kun se on lukittu. Näyttö sammuu edelleen järjestelmän asetuksissa määritetyn normaalin ajan kuluttua."

msgid "Prompt Animation"
msgstr "Salasanakentän animaatio"

msgid "Reset Animations"
msgstr "Palauta animaatiot"

msgid "Reset animations"
msgstr "Nollaa animaatiot"

msgid "Resources"
msgstr "Resurssit"

msgid "Restore defaults"
msgstr "Palauta oletusasetukset"

msgid "Saweria"
msgstr "Saweria"

msgid "Show a custom message above the user prompt stack."
msgstr "Näyttää mukautetun viestin käyttäjän kirjautumiskentän yläpuolella."

msgid "Screen Timeout"
msgstr "Näytön aikakatkaisu"

msgid "Time to wait before turning off the screen"
msgstr "Odotusaika ennen näytön sammuttamista"

msgid "Extras"
msgstr "Lisäominaisuudet"

msgid "[PRO] GDM Expansion"
msgstr "[PRO] GDM-laajennus"

msgid "Enabled. Custom layout is active on GDM."
msgstr "Käytössä. Mukautettu asettelu on käytössä GDM:ssä."

msgid "Enabled"
msgstr "Käytössä"

msgid "Disabled"
msgstr "Ei käytössä"

msgid "Disabled."
msgstr "Ei käytössä."

msgid "GDM and Cross Session Module are missing."
msgstr "GDM- ja Cross Session -moduulit puuttuvat."

msgid "GDM dconf override configuration is missing."
msgstr "GDM dconf -ohituskokoonpano puuttuu."

msgid "GDM integration is not configured."
msgstr "GDM-integraatiota ei ole määritetty."

msgid "Upgrade to Pro"
msgstr "Päivitä Pro-versioon"

msgid "Get a Sonoma-inspired GDM login screen layout and automatically synchronize your wallpapers from the active user session. To upgrade, run copied command in a terminal."
msgstr "Hanki Sonoman inspiroima GDM-kirjautumisruudun asettelu ja synkronoi taustakuvasi automaattisesti aktiivisesta käyttäjäistunnosta. Päivitä suorittamalla kopioitu komento päätteessä."

msgid "Copy upgrade command to clipboard"
msgstr "Kopioi päivityskomento leikepöydälle"

msgid "Copied upgrade command to clipboard!"
msgstr "Päivityskomento kopioitu leikepöydälle!"

msgid "Uninstall GDM Expansion"
msgstr "Poista GDM-laajennuksen asennus"

msgid "Revert GDM login screen layout to GNOME Default. To uninstall, run copied command in a terminal."
msgstr "Palauta GDM-kirjautumisruudun asettelu GNOME-oletukseksi. Poista asennus suorittamalla kopioitu komento päätteessä."

msgid "Copy uninstall command to clipboard"
msgstr "Kopioi poistokomento leikepöydälle"

msgid "Copied uninstall command to clipboard!"
msgstr "Poistokomento kopioitu leikepöydälle!"

msgid "[BETA] WACK Shell Integration"
msgstr "[BETA] WACK Shell -integraatio"

msgid "Installed. Enables crossfade transitions and Cupertino-inspired shell customisations."
msgstr "Asennettu. Ottaa käyttöön ristiinhäivytyssiirtymät ja Cupertinon inspiroimat shell-mukautukset."

msgid "Upgrade to [PRO]"
msgstr "Päivitä [PRO]-versioon"

msgid "Installed"
msgstr "Asennettu"

msgid "Not installed. Install WACK Shell to unlock transition effects."
msgstr "Ei asennettu. Asenna WACK Shell ottaaksesi siirtymätehosteet käyttöön."

msgid "Not Installed"
msgstr "Ei asennettu"

msgid "Install WACK Shell"
msgstr "Asenna WACK Shell"

msgid "Get advanced desktop crossfade transitions and Cupertino-inspired shell customisations. May contain bugs, report if found."
msgstr "Hanki edistyneet työpöydän ristiinhäivytyssiirtymät ja Cupertinon inspiroimat shell-mukautukset. Saattaa sisältää virheitä, ilmoita niistä tarvittaessa."

msgid "Copy install command to clipboard"
msgstr "Kopioi asennuskomento leikepöydälle"

msgid "Copied WACK Shell install command to clipboard!"
msgstr "WACK Shell -asennuskomento kopioitu leikepöydälle!"

msgid "Open WACK Shell repository"
msgstr "Avaa WACK Shell -arkisto"

msgid "Check for Updates"
msgstr "Tarkista päivitykset"

msgid "Copy check command to verify if a newer version of WACK Shell is available."
msgstr "Kopioi tarkistuskomento varmistaaksesi, onko uudempi WACK Shell -versio saatavilla."

msgid "Copy update-check command to clipboard"
msgstr "Kopioi päivityksen tarkistuskomento leikepöydälle"

msgid "Copied WACK Shell update-check command to clipboard!"
msgstr "WACK Shell -päivityksen tarkistuskomento kopioitu leikepöydälle!"

