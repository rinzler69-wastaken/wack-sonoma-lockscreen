msgid "more"
msgstr "lisää"

msgid "Press Shift + N to view notifications"
msgstr "Paina Shift + N nähdäksesi ilmoitukset"

msgid "Sleep prevented by an active process"
msgstr "Valmiustila estetty aktiivisen prosessin toimesta"

msgid "1 minute"
msgstr "1 minuutti"

msgid "10 minutes"
msgstr "10 minuuttia"

msgid "15 minutes"
msgstr "15 minuuttia"

