msgid "more"
msgstr "περισσότερα"

msgid "Press Shift + N to view notifications"
msgstr "Πατήστε Shift + N για προβολή ειδοποιήσεων"

msgid "Sleep prevented by an active process"
msgstr "Η αναστολή λειτουργίας αποτράπηκε από μια ενεργή διεργασία"

msgid "1 minute"
msgstr "1 λεπτό"

msgid "10 minutes"
msgstr "10 λεπτά"

msgid "15 minutes"
msgstr "15 λεπτά"

msgid "2 hours"
msgstr "2 ώρες"

msgid "30 minutes"
msgstr "30 λεπτά"

msgid "5 minutes"
msgstr "5 λεπτά"

msgid "60 minutes"
msgstr "60 λεπτά"

msgid "Always Show User Widget (Cupertino)"
msgstr "Να εμφανίζεται πάντα το γραφικό στοιχείο χρήστη (Cupertino)"

msgid "Always shows user widget, hides notifications by default. Press Shift+N to show notifications."
msgstr "Εμφανίζει πάντα το γραφικό στοιχείο χρήστη, αποκρύπτοντας τις ειδοποιήσεις από προεπιλογή. Πατήστε Shift+N για να εμφανιστούν οι ειδοποιήσεις."

msgid "Animations"
msgstr "Κινούμενα σχέδια"

msgid "Applied to the authentication prompt while it appears"
msgstr "Εφαρμόζεται στο μήνυμα ελέγχου ταυτότητας ενώ εμφανίζεται"

msgid "Applied to the date and time while opening the password prompt"
msgstr "Εφαρμόζεται στην ημερομηνία και την ώρα κατά το άνοιγμα του πλαισίου κωδικού"

msgid "Blank Timeout"
msgstr "Χρονικό όριο απενεργοποίησης οθόνης"

msgid "A complete macOS Sonoma-inspired lockscreen layout (Click user-icon to switch users)."
msgstr "Μια πλήρης διάταξη οθόνης κλειδώματος εμπνευσμένη από το macOS Sonoma (κάντε κλικ στο εικονίδιο χρήστη για εναλλαγή χρηστών)."

msgid "macOS Sonoma-style clock over the classic, GNOME-compliant layout and flow."
msgstr "Ρολόι στυλ macOS Sonoma πάνω από την κλασική, συμβατή με το GNOME διάταξη και ροή."

msgid "Unlock Crossfade"
msgstr "Ξεθώριασμα ξεκλειδώματος"

msgid "Crossfade the lockscreen with desktop when unlocking (automatically disabled in Power Saver mode)."
msgstr "Ξεθωριάζει την οθόνη κλειδώματος με την επιφάνεια εργασίας κατά το ξεκλείδωμα (απενεργοποιείται αυτόματα στη λειτουργία εξοικονόμησης ενέργειας)."

msgid "Crossfade Speed"
msgstr "Ταχύτητα ξεθωριάσματος"

msgid "Cupertino Unlock Fade"
msgstr "Ξεθώριασμα ξεκλειδώματος Cupertino"

msgid "Fade out the lock screen with a panel slide-in when unlocking."
msgstr "Σταδιακό σβήσιμο της οθόνης κλειδώματος με ολίσθηση του πίνακα κατά το ξεκλείδωμα."

msgid "Choose between Legacy and Cupertino styles"
msgstr "Επιλογή μεταξύ του κλασικού στυλ και του στυλ Cupertino"

msgid "Choose how the lock screen clock leaves and how the password prompt enters."
msgstr "Επιλέξτε πώς εξαφανίζεται το ρολόι της οθόνης κλειδώματος και πώς εμφανίζεται το πλαίσιο κωδικού."

msgid "Clock Animation"
msgstr "Κινούμενα σχέδια ρολογιού"

msgid "Configuration"
msgstr "Διαμόρφωση"

msgid "Consider supporting its development!"
msgstr "Σκεφτείτε να υποστηρίξετε την ανάπτυξή του!"

msgid "Control when the screen turns off or blanks on the lock screen."
msgstr "Ελέγχει πότε η οθόνη απενεργοποιείται ή μαυρίζει στην οθόνη κλειδώματος."

msgid "Cupertino"
msgstr "Κουπερτίνο"

msgid "Enjoying this extension?"
msgstr "Σας αρέσει αυτή η επέκταση;"

msgid "Escape to Sleep / Suspend"
msgstr "Esc για απενεργοποίηση οθόνης / αναστολή"

msgid "Extension Repo"
msgstr "Επέκταση Repo"

msgid "Home"
msgstr "Αρχική"

msgid "Keep Screen On"
msgstr "Διατήρηση της οθόνης ενεργής"

msgid "Ko-fi"
msgstr "Κο-φι"

msgid "Legacy"
msgstr "Κλασικό"

msgid "Lockscreen Mode"
msgstr "Λειτουργία οθόνης κλειδώματος"

msgid "Show message when locked"
msgstr "Εμφάνιση μηνύματος κατά το κλείδωμα"

msgid "Set..."
msgstr "Ορισμός..."

msgid "Set a message to appear on the lockscreen"
msgstr "Ορίστε ένα μήνυμα για εμφάνιση στην οθόνη κλειدودματος"

msgid "Cancel"
msgstr "Ακύρωση"

msgid "OK"
msgstr "OK"

msgid "Mode"
msgstr "Τρόπος"

msgid "Never"
msgstr "Ποτέ"

msgid "Only keep the screen on if the system is plugged in"
msgstr "Διατήρηση της οθόνης ενεργής μόνο κατά τη σύνδεση στο ρεύμα"

msgid "Only on AC Power"
msgstr "Μόνο κατά τη σύνδεση στο ρεύμα"

msgid "Open Ko-fi"
msgstr "Άνοιγμα Ko-fi"

msgid "Open Saweria"
msgstr "Άνοιγμα Saweria"

msgid "Open on GitHub"
msgstr "Άνοιγμα στο GitHub"

msgid "Press Escape on the lock screen to sleep display (or suspend)"
msgstr "Πατήστε Esc στην οθόνη κλειδώματος για απενεργοποίηση της οθόνης (ή αναστολή)"

msgid "Prevent the screen from immediately turning off when locked. The screen will still turn off after the normal timeout duration set in system settings."
msgstr "Αποτρέπει την άμεση απενεργοποίηση της οθόνης κατά το κλείδωμα. Η οθόνη θα απενεργοποιηθεί μετά την κανονική διάρκεια που έχει οριστεί στις ρυθμίσεις συστήματος."

msgid "Prompt Animation"
msgstr "Κινούμενα σχέδια πλαισίου κωδικού"

msgid "Reset Animations"
msgstr "Επαναφορά κινούμενων εικόνων"

msgid "Reset animations"
msgstr "Επαναφορά κινούμενων εικόνων"

msgid "Resources"
msgstr "Πόροι"

msgid "Restore defaults"
msgstr "Επαναφορά προεπιλογών"

msgid "Saweria"
msgstr "Saweria"

msgid "Show a custom message above the user prompt stack."
msgstr "Εμφάνιση προσαρμοσμένου μηνύματος πάνω από το πλαίσιο εισόδου του χρήστη."

msgid "Screen Timeout"
msgstr "Λήξη χρονικού ορίου οθόνης"

msgid "Time to wait before turning off the screen"
msgstr "Χρόνος αναμονής πριν την απενεργοποίηση της οθόνης"

msgid "Extras"
msgstr "Πρόσθετα"

msgid "[PRO] GDM Expansion"
msgstr "[PRO] Επέκταση GDM"

msgid "Enabled. Custom layout is active on GDM."
msgstr "Ενεργοποιημένο. Η προσαρμοσμένη διάταξη είναι ενεργή στο GDM."

msgid "Enabled"
msgstr "Ενεργοποιημένο"

msgid "Disabled"
msgstr "Απενεργοποιημένο"

msgid "Disabled."
msgstr "Απενεργοποιημένο."

msgid "GDM and Cross Session Module are missing."
msgstr "Τα πρόσθετα GDM και Cross Session λείπουν."

msgid "GDM dconf override configuration is missing."
msgstr "Η παραμετροποίηση παράκαμψης dconf του GDM λείπει."

msgid "GDM integration is not configured."
msgstr "Η ενσωμάτωση GDM δεν έχει ρυθμιστεί."

msgid "Upgrade to Pro"
msgstr "Αναβάθμιση σε Pro"

msgid "Get a Sonoma-inspired GDM login screen layout and automatically synchronize your wallpapers from the active user session. To upgrade, run copied command in a terminal."
msgstr "Αποκτήστε μια διάταξη οθόνης σύνδεσης GDM εμπνευσμένη από το Sonoma και συγχρονίστε αυτόματα τις ταπετσαρίες σας από την ενεργή συνεδρία χρήστη. Για αναβάθμιση, εκτελέστε την αντιγραμμένη εντολή σε ένα τερματικό."

msgid "Copy upgrade command to clipboard"
msgstr "Αντιγραφή εντολής αναβάθμισης στο πρόχειρο"

msgid "Copied upgrade command to clipboard!"
msgstr "Η εντολή αναβάθμισης αντιγράφηκε στο πρόχειρο!"

msgid "Uninstall GDM Expansion"
msgstr "Απεγκατάσταση επέκτασης GDM"

msgid "Revert GDM login screen layout to GNOME Default. To uninstall, run copied command in a terminal."
msgstr "Επαναφορά της διάταξης οθόνης σύνδεσης GDM στην προεπιλογή του GNOME. Για απεγκατάσταση, εκτελέστε την αντιγραμμένη εντολή σε ένα τερματικό."

msgid "Copy uninstall command to clipboard"
msgstr "Αντιγραφή εντολής απεγκατάστασης στο πρόχειρο"

msgid "Copied uninstall command to clipboard!"
msgstr "Η εντολή απεγκατάστασης αντιγράφηκε στο πρόχειρο!"

msgid "[BETA] WACK Shell Integration"
msgstr "[BETA] Ενσωμάτωση WACK Shell"

msgid "Installed. Enables crossfade transitions and Cupertino-inspired shell customisations."
msgstr "Εγκαταστάθηκε. Επιτρέπει μεταβάσεις ξεθωριάσματος και προσαρμογές κελύφους εμπνευσμένες από το Cupertino."

msgid "Upgrade to [PRO]"
msgstr "Αναβάθμιση σε [PRO]"

msgid "Installed"
msgstr "Εγκαταστάθηκε"

msgid "Not installed. Install WACK Shell to unlock transition effects."
msgstr "Δεν εγκαταστάθηκε. Εγκαταστήστε το WACK Shell για να ξεκλειδώσετε τα εφέ μετάβασης."

msgid "Not Installed"
msgstr "Δεν εγκαταστάθηκε"

msgid "Install WACK Shell"
msgstr "Εγκατάσταση WACK Shell"

msgid "Get advanced desktop crossfade transitions and Cupertino-inspired shell customisations. May contain bugs, report if found."
msgstr "Αποκτήστε προηγμένες μεταβάσεις ξεθωριάσματος επιφάνειας εργασίας και προσαρμογές κελύφους εμπνευσμένες από το Cupertino. Μπορεί να περιέχει σφάλματα, αναφέρετέ τα εάν βρεθούν."

msgid "Copy install command to clipboard"
msgstr "Αντιγραφή εντολής εγκατάστασης στο πρόχειρο"

msgid "Copied WACK Shell install command to clipboard!"
msgstr "Η εντολή εγκατάστασης WACK Shell αντιγράφηκε στο πρόχειρο!"

msgid "Open WACK Shell repository"
msgstr "Άνοιγμα αποθετηρίου WACK Shell"

msgid "Check for Updates"
msgstr "Έλεγχος για ενημερώσεις"

msgid "Copy check command to verify if a newer version of WACK Shell is available."
msgstr "Αντιγράψτε την εντολή ελέγχου για να επαληθεύσετε εάν είναι διαθέσιμη μια νεότερη έκδοση του WACK Shell."

msgid "Copy update-check command to clipboard"
msgstr "Αντιγραφή εντολής ελέγχου ενημέρωσης στο πρόχειρο"

msgid "Copied WACK Shell update-check command to clipboard!"
msgstr "Η εντολή ελέγχου ενημέρωσης του WACK Shell αντιγράφηκε στο πρόχειρο!"

msgid "Extras - Status"
msgstr "Πρόσθετα - Κατάσταση"

msgid "Extras - Actions"
msgstr "Πρόσθετα - Ενέργειες"

msgid "GDM Expansion - Remove"
msgstr "Επέκταση GDM - Κατάργηση"

msgid "WACK Shell - Check for Updates"
msgstr "WACK Shell - Έλεγχος για ενημερώσεις"

msgid "WACK Shell - Install"
msgstr "WACK Shell - Εγκατάσταση"

msgid "Upcoming Features"
msgstr "Επικείμενες λειτουργίες"

msgid "Learn how to unlock system-wide login customisations, transitions, and other advanced features on GitHub."
msgstr "Μάθετε πώς να ξεκλειδώσετε τις προσαρμογές σύνδεσης σε επίπεδο συστήματος, τις μεταβάσεις και άλλες προηγμένες λειτουργίες στο GitHub."

