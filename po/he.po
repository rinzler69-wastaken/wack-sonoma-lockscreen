msgid "[PRO] GDM Expansion"
msgstr "[PRO] הרחבת GDM"

msgid "Enabled. Custom layout is active on GDM."
msgstr "פעיל. פריסה מותאמת אישית מופελת ב־GDM."

msgid "Enabled"
msgstr "פעיל"

msgid "Disabled"
msgstr "כבוי"

