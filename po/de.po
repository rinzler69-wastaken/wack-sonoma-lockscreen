msgid "more"
msgstr "mehr"

msgid "Press Shift + N to view notifications"
msgstr "Shift + N drücken, um Benachrichtigungen anzuzeigen"

msgid "Sleep prevented by an active process"
msgstr "Bereitschaft durch einen aktiven Prozess verhindert"

msgid "1 minute"
msgstr "1 Minute"

msgid "10 minutes"
msgstr "10 Minuten"

msgid "15 minutes"
msgstr "15 Minuten"

msgid "2 hours"
msgstr "2 Stunden"

