msgstr "Cupertino"

msgid "Enjoying this extension?"
msgstr "Gefällt Ihnen diese Erweiterung?"

msgid "Escape to Sleep / Suspend"
msgstr "Escape für Bildschirm aus / Bereitschaft"

msgid "Extension Repo"
msgstr "Erweiterungs-Repo"

