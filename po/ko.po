msgstr "확장 레포"

msgid "Home"
msgstr "홈"

msgid "Keep Screen On"
msgstr "화면 켜짐 유지"

msgid "Ko-fi"
msgstr "코파이"

msgid "Legacy"
msgstr "클래식"

msgid "Lockscreen Mode"
