msgid "Prevent the screen from blanking or turning off when locked"
msgstr "Ngăn màn hình bị tắt hoặc tối khi bị khóa"

msgid "Prompt Animation"
msgstr "Hoạt ảnh của hộp nhập mật khẩu"

