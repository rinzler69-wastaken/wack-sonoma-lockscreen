msgstr "5 dakika"

msgid "60 minutes"
msgstr "60 dakika"

msgid "Always Show User Widget (Cupertino)"
msgstr "Her Zaman Kullanıcı Widget'ını Göster (Cupertino)"

msgid "Always shows user widget, hides notifications by default. Press Shift+N to show notifications."
msgstr "Kullanıcı widget'ını her zaman gösterir, bildirimleri varsayılan olarak gizler. Bildirimleri göstermek için Shift+N tuşlarına basın."

msgid "Animations"
msgstr "Animasyonlar"

msgid "Applied to the authentication prompt while it appears"
msgstr "Göründüğü sırada kimlik doğrulama istemine uygulandı"

msgid "Applied to the date and time while opening the password prompt"
msgstr "Parola istemi açılırken tarih ve saate uygulanır"

msgid "Blank Timeout"
msgstr "Ekran Kapanma Zaman Aşımı"

msgid "A complete macOS Sonoma-inspired lockscreen layout (Click user-icon to switch users)."
msgstr "macOS Sonoma esintili eksiksiz kilit ekranı düzeni (Kullanıcı değiştirmek için kullanıcı simgesine tıklayın)."

msgid "macOS Sonoma-style clock over the classic, GNOME-compliant layout and flow."
msgstr "Klasik, GNOME uyumlu düzen ve akış üzerinde macOS Sonoma tarzı saat."

msgid "Unlock Crossfade"
msgstr "Kilit Açma Solması"

msgid "Crossfade the lockscreen with desktop when unlocking (automatically disabled in Power Saver mode)."
msgstr "Kilit açılırken kilit ekranını masaüstüyle yavaşça soldurur (Güç Tasarrufu modunda otomatik olarak devre dışı bırakılır)."

msgid "Crossfade Speed"
msgstr "Solma Hızı"

msgid "Cupertino Unlock Fade"
msgstr "Cupertino Kilit Açma Solması"

msgid "Fade out the lock screen with a panel slide-in when unlocking."
msgstr "Kilit açılırken panelin içeri kaymasıyla kilit ekranını yavaşça soldurur."

msgid "Choose between Legacy and Cupertino styles"
msgstr "Klasik ve Cupertino stilleri arasından seçim yapın"

msgid "Choose how the lock screen clock leaves and how the password prompt enters."
msgstr "Kilit ekranı saatinin nasıl kaybolacağını ve parola isteminin nasıl görüneceğini seçin."

msgid "Clock Animation"
msgstr "Saat Animasyonu"

msgid "Configuration"
msgstr "Yapılandırma"

msgid "Consider supporting its development!"
msgstr "Gelişimini desteklemeyi düşünün!"

msgid "Control when the screen turns off or blanks on the lock screen."
msgstr "Kilit ekranında ekranın ne zaman kapanacağını veya kararacağını kontrol edin."

msgid "Cupertino"
msgstr "Cupertino"

msgid "Enjoying this extension?"
msgstr "Bu uzantıyı beğeniyor musunuz?"

msgid "Escape to Sleep / Suspend"
msgstr "Ekranı Kapatmak / Askıya Almak için Esc"

msgid "Extension Repo"
msgstr "Uzantı Deposu"

msgid "Home"
msgstr "Ana Sayfa"

msgid "Keep Screen On"
msgstr "Ekranı Açık Tut"

msgid "Ko-fi"
msgstr "Ko-fi"

msgid "Legacy"
msgstr "Klasik"

msgid "Lockscreen Mode"
msgstr "Kilit Ekranı Modu"

msgid "Show message when locked"
msgstr "Kilitliyken mesajı göster"

msgid "Set..."
msgstr "Ayarla..."

msgid "Set a message to appear on the lockscreen"
msgstr "Kilit ekranında görünecek bir mesaj ayarla"

msgid "Cancel"
msgstr "İptal"

msgid "OK"
msgstr "Tamam"

msgid "Mode"
msgstr "Mod"

