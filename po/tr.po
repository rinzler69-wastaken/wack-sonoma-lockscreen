msgid "more"
msgstr "daha fazla"

msgid "Press Shift + N to view notifications"
msgstr "Bildirimleri görmek için Shift + N'ye basın"

msgid "Sleep prevented by an active process"
msgstr "Askıya alma etkin bir işlem tarafından engellendi"

msgid "1 minute"
msgstr "1 dakika"

msgid "10 minutes"
msgstr "10 dakika"

msgid "15 minutes"
msgstr "15 dakika"

msgid "2 hours"
msgstr "2 saat"

msgid "30 minutes"
msgstr "30 dakika"

