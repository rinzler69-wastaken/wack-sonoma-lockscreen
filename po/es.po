msgid "Always Show User Widget (Cupertino)"
msgstr "Mostrar siempre el widget de usuario (Cupertino)"

msgid "Always shows user widget, hides notifications by default. Press Shift+N to show notifications."
msgstr "Muestra siempre el widget de usuario y oculta las notificaciones por defecto. Presione Shift+N para ver las notificaciones."

msgid "Animations"
msgstr "Animaciones"

msgid "Applied to the authentication prompt while it appears"
msgstr "Se aplica al mensaje de autenticación mientras aparece."

msgid "Applied to the date and time while opening the password prompt"
msgstr "Se aplica a la fecha y hora al abrir el indicador de contraseña"

msgid "Blank Timeout"
msgstr "Tiempo de espera de apagado de pantalla"

msgid "A complete macOS Sonoma-inspired lockscreen layout (Click user-icon to switch users)."
msgstr "Diseño completo inspirado en macOS Sonoma (haga clic en el icono de usuario para cambiar de usuario)."

msgid "macOS Sonoma-style clock over the classic, GNOME-compliant layout and flow."
msgstr "Reloj estilo macOS Sonoma sobre el diseño y flujo clásico compatible con GNOME."

msgid "Cupertino Unlock Fade"
msgstr "Desvanecimiento de desbloqueo Cupertino"

msgid "Fade out the lock screen with a panel slide-in when unlocking."
