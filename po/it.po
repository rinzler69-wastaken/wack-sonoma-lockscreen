msgstr "Extra - Stato"

msgid "Extras - Actions"
msgstr "Extra - Azioni"

msgid "GDM Expansion - Remove"
msgstr "Estensione GDM - Rimuovi"

msgid "WACK Shell - Check for Updates"
msgstr "WACK Shell - Verifica aggiornamenti"

msgid "WACK Shell - Install"
msgstr "WACK Shell - Installa"

msgid "Upcoming Features"
msgstr "Prossime funzioni"

msgid "Check out this extension's GitHub repo for cool features in the works."
msgstr "Visita il repository GitHub di questa estensione per scoprire le funzioni in sviluppo."

