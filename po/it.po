msgid "more"
msgstr "altro"

msgid "Press Shift + N to view notifications"
msgstr "Premi Maiusc + N per visualizzare le notifiche"

msgid "Sleep prevented by an active process"
msgstr "Sospensione impedita da un processo attivo"

msgid "1 minute"
msgstr "1 minuto"

msgid "10 minutes"
msgstr "10 minuti"

msgid "15 minutes"
msgstr "15 minuti"

msgid "2 hours"
msgstr "2 ore"

