msgid "Upgrade to Pro"
msgstr "Uppgradera till Pro"

msgid "Get a Sonoma-inspired GDM login screen layout and automatically synchronize your wallpapers from the active user session. To upgrade, run copied command in a terminal."
msgstr "Få en Sonoma-inspirerad GDM-inloggningsskärmslayout och synkronisera dina bakgrundsbilder automatiskt från den aktiva användarsessionen. För att uppgradera, kör det kopierade kommandot i een terminal."

msgid "Copy upgrade command to clipboard"
msgstr "Kopiera uppgraderingskommandot till urklipp"

msgid "Copied upgrade command to clipboard!"
msgstr "Uppgraderingskommandot har kopierats till urklipp!"

msgid "Uninstall GDM Expansion"
msgstr "Avinstallera GDM-utökning"

msgid "Revert GDM login screen layout to GNOME Default. To uninstall, run copied command in a terminal."
msgstr "Återställ GDM-inloggningsskärmens layout till GNOME Default. För avinstallation, kör det kopierade kommandot i een terminal."

msgid "Copy uninstall command to clipboard"
msgstr "Kopiera avinstallationskommandot till urklipp"

msgid "Copied uninstall command to clipboard!"
msgstr "Avinstallationskommandot har kopierats till urklipp!"

msgid "[BETA] WACK Shell Integration"
msgstr "[BETA] WACK Shell-integrering"

