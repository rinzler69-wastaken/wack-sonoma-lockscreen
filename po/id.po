msgid "Press Shift + N to view notifications"
msgstr "Tekan Shift + N untuk melihat notifikasi"

msgid "Sleep prevented by an active process"
msgstr "Mode tidur dicegah oleh proses aktif"

msgid "1 minute"
msgstr "1 menit"

msgid "10 minutes"
msgstr "10 menit"

