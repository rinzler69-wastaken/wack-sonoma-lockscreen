msgid "more"
msgstr "المزيد"

msgid "Press Shift + N to view notifications"
msgstr "اضغط Shift + N لعرض الإشعارات"

msgid "Sleep prevented by an active process"
msgstr "تم منع التعليق بواسطة عملية نشطة"

msgid "1 minute"
msgstr "1 دقيقة"

msgid "10 minutes"
msgstr "10 دقائق"

msgid "15 minutes"
msgstr "15 دقيقة"

msgid "2 hours"
msgstr "ساعاتين"

msgid "30 minutes"
msgstr "30 دقيقة"

msgid "5 minutes"
msgstr "5 دقائق"

msgid "60 minutes"
msgstr "60 دقيقة"

msgid "Always Show User Widget (Cupertino)"
msgstr "إظهار أداة المستخدم دائمًا (كوبرتينو)"

msgid "Always shows user widget, hides notifications by default. Press Shift+N to show notifications."
msgstr "يعرض دائمًا عنصر واجهة المستخدم للمستخدم، ويخفي الإشعارات افتراضيًا. اضغط على Shift+N لإظهار الإشعارات."

msgid "Animations"
msgstr "الرسوم المتحركة"

msgid "Applied to the authentication prompt while it appears"
msgstr "يتم تطبيقه على موجه المصادقة أثناء ظهوره"

msgid "Applied to the date and time while opening the password prompt"
msgstr "تطبق على التاريخ والوقت أثناء فتح حقل كلمة المرور"

msgid "Blank Timeout"
msgstr "مهلة إطفاء الشاشة"

msgid "A complete macOS Sonoma-inspired lockscreen layout (Click user-icon to switch users)."
msgstr "مظهر كامل لـ قفل الشاشة مستوحى من macOS Sonoma (انقر على أيقونة المستخدم للتبديل بين المستخدمين)."

msgid "macOS Sonoma-style clock over the classic, GNOME-compliant layout and flow."
msgstr "ساعة بنمط macOS Sonoma فوق واجهة مستخدم وسير عمل GNOME الافتراضي."

msgid "Unlock Crossfade"
msgstr "تلاشي فتح القفل"

msgid "Crossfade the lockscreen with desktop when unlocking (automatically disabled in Power Saver mode)."
msgstr "تلاشي شاشة القفل مع سطح المكتب عند فتح القفل (يتم إيقاف تشغيله تلقائيًا في وضع توفير الطاقة)."

msgid "Crossfade Speed"
msgstr "سرعة التلاشي"

msgid "Cupertino Unlock Fade"
msgstr "تلاشي فتح قفل كوبرتينו"

msgid "Fade out the lock screen with a panel slide-in when unlocking."
msgstr "تلاشي شاشة القفل مع انزلاق اللوحة للداخل عند فتح القفل."

msgid "Choose between Legacy and Cupertino styles"
msgstr "اختر بين النمط الكلاسيكي ونمط Cupertino"

msgid "Choose how the lock screen clock leaves and how the password prompt enters."
msgstr "اختر حركة اختفاء ساعة قفل الشاشة وحركة ظهور حقل كلمة المرور."

msgid "Clock Animation"
msgstr "الرسوم المتحركة على مدار الساعة"

msgid "Configuration"
msgstr "إعدادات"

msgid "Consider supporting its development!"
msgstr "النظر في دعم تطويرها!"

msgid "Control when the screen turns off or blanks on the lock screen."
msgstr "التحكم في وقت إطفاء الشاشة أو تعتيمها على شاشة القفل."

msgid "Cupertino"
msgstr "كوبرتينو"

msgid "Enjoying this extension?"
msgstr "هل تستمتع بهذا الامتداد؟"

msgid "Escape to Sleep / Suspend"
msgstr "Esc لإطفاء الشاشة / التعليق"

msgid "Extension Repo"
msgstr "تمديد الريبو"

msgid "Home"
msgstr "الرئيسية"

msgid "Keep Screen On"
msgstr "إبقاء الشاشة قيد التشغيل"

msgid "Ko-fi"
msgstr "كو فاي"

msgid "Legacy"
msgstr "كلاسيكي"

msgid "Lockscreen Mode"
msgstr "وضع قفل الشاشة"

msgid "Mode"
msgstr "وضع"

msgid "Never"
msgstr "أبداً"

msgid "Only keep the screen on if the system is plugged in"
msgstr "إبقاء الشاشة تعمل فقط عند التوصيل بالكهرباء"

msgid "Only on AC Power"
msgstr "عند التوصيل بالكهرباء فقط"

msgid "Open Ko-fi"
msgstr "افتح Ko-fi"

msgid "Open Saweria"
msgstr "افتح Saweria"

msgid "Open on GitHub"
msgstr "افتح على GitHub"

msgid "Press Escape on the lock screen to sleep display (or suspend)"
msgstr "اضغط على Esc في شاشة القفل لإطفاء الشاشة (أو التعليق)"

msgid "Prevent the screen from immediately turning off when locked. The screen will still turn off after the normal timeout duration set in system settings."
msgstr "منع الشاشة من الانطفاء فورًا عند القفل. ستستمر الشاشة في الانطفاء بعد فترة المهلة العادية المحددة في إعدادات النظام."

msgid "Prompt Animation"
msgstr "حركة حقل كلمة المرور"

msgid "Reset Animations"
msgstr "إعادة تعيين الرسوم المتحركة"

msgid "Reset animations"
msgstr "إعادة تعيين الرسوم المتحركة"

msgid "Resources"
msgstr "موارد"

msgid "Restore defaults"
msgstr "استعادة الإعدادات الافتراضية"

msgid "Saweria"
msgstr "ساويرية"

msgid "Screen Timeout"
msgstr "مهلة الشاشة"

msgid "Time to wait before turning off the screen"
msgstr "المدة الزمنية sebelum إطفاء الشاشة"

