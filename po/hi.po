msgid "more"
msgstr "अधिक"

msgid "Press Shift + N to view notifications"
msgstr "सूचनाएं देखने के लिए Shift + N दबाएं"

msgid "Sleep prevented by an active process"
msgstr "एक सक्रिय प्रक्रिया द्वारा निलंबن रोका गया"

msgid "1 minute"
msgstr "1 मिनट"

msgid "10 minutes"
msgstr "10 मिनटों"

msgid "15 minutes"
msgstr "15 मिनटों"

msgid "2 hours"
msgstr "2 घंटे"

msgid "30 minutes"
msgstr "30 मिनट"

msgid "5 minutes"
msgstr "5 मिनट"

msgid "60 minutes"
msgstr "60 मिनट"

msgid "Always Show User Widget (Cupertino)"
msgstr "हमेशा उपयोगकर्ता विजेट दिखाएँ (क्यूपर्टिनो)"

msgid "Always shows user widget, hides notifications by default. Press Shift+N to show notifications."
msgstr "हमेशा उपयोगकर्ता विजेट दिखाता है, डिफ़ॉल्ट रूप से सूचनाएं छुपाता है। सूचनाएं दिखाने के लिए Shift+N दबाएं।"

msgid "Animations"
msgstr "एनिमेशन"

msgid "Applied to the authentication prompt while it appears"
msgstr "प्रमाणीकरण संकेत प्रकट होने पर उस पर लागू किया गया"

msgid "Applied to the date and time while opening the password prompt"
msgstr "पासवर्ड संकेत खोलते समय दिनांक और समय पर लागू होता है"

msgid "Blank Timeout"
msgstr "स्क्रीन बंद होने का समय"

msgid "A complete macOS Sonoma-inspired lockscreen layout (Click user-icon to switch users)."
msgstr "एक पूर्ण macOS सोनोमा-प्रेरित लॉकस्क्रीन लेआउट (उपयोगकर्ताओं को बदलने के लिए उपयोगकर्ता-आइकन पर क्लिक करें)।"

msgid "macOS Sonoma-style clock over the classic, GNOME-compliant layout and flow."
msgstr "क्लासिक, जीनोम-अनुरूप लेआउट और फ्लो पर macOS सोनोमा-शैली की घड़ी।"

msgid "Unlock Crossfade"
msgstr "अनलॉक क्रॉसफ़ेड"

msgid "Crossfade the lockscreen with desktop when unlocking (automatically disabled in Power Saver mode)."
msgstr "अनलॉक करते समय डेस्कटॉप के साथ锁屏 को क्रॉसफ़ेड करें (बैटरी सेवर मोड में स्वचालित रूप से अक्षम)।"

msgid "Crossfade Speed"
msgstr "क्रॉसफ़ेड गति"

msgid "Cupertino Unlock Fade"
msgstr "क्यूपर्टिनो अनलॉक फ़ेड"

msgid "Fade out the lock screen with a panel slide-in when unlocking."
msgstr "अनलॉक करते समय पैनल के स्लाइड-इन के साथ लॉक स्क्रीन को फ़ेड आउट करें।"

msgid "Choose between Legacy and Cupertino styles"
msgstr "क्लासिक और क्यूपर्टिनो शैलियों के बीच चयन करें"

msgid "Choose how the lock screen clock leaves and how the password prompt enters."
msgstr "चुनें कि लॉक स्क्रीन घड़ी कैसे गायब होती है और पासवर्ड प्रॉम्प्ट कैसे प्रवेश करता है।"

msgid "Clock Animation"
msgstr "घड़ी एनीमेशन"

msgid "Configuration"
msgstr "विन्यास"

msgid "Consider supporting its development!"
msgstr "इसके विकास का समर्थन करने पर विचार करें!"

msgid "Control when the screen turns off or blanks on the lock screen."
msgstr "नियंत्रित करें कि लॉक स्क्रीन पर स्क्रीन कब बंद या धुंधली होती है।"

msgid "Cupertino"
msgstr "क्यूपर्टिनो"

msgid "Enjoying this extension?"
msgstr "इस विस्तार का आनंद ले रहे हैं?"

msgid "Escape to Sleep / Suspend"
msgstr "स्क्रीन बंद / निलंबित करने के लिए Esc"

msgid "Extension Repo"
msgstr "एक्सटेंशन रेपो"

msgid "Home"
msgstr "मुख्य पृष्ठ"

msgid "Keep Screen On"
msgstr "स्क्रीन चालू रखें"

msgid "Ko-fi"
msgstr "को-फाई"

msgid "Legacy"
msgstr "क्लासिक"

msgid "Lockscreen Mode"
msgstr "लॉकस्क्रीन मोड"

msgid "Show message when locked"
msgstr "लॉक होने पर संदेश दिखाएं"

msgid "Set..."
msgstr "सेट करें..."

msgid "Set a message to appear on the lockscreen"
msgstr "लॉकस्क्रीन पर दिखने के लिए एक संदेश सेट करें"

msgid "Cancel"
msgstr "रद्द करें"

msgid "OK"
msgstr "ठीक है"

msgid "Mode"
msgstr "तरीका"

msgid "Never"
msgstr "कभी नहीं"

msgid "Only keep the screen on if the system is plugged in"
msgstr "स्क्रीन केवल तब चालू रखें जब सिस्टम प्लग इन हो"

msgid "Only on AC Power"
msgstr "केवल एसी पावर पर"

msgid "Open Ko-fi"
msgstr "Ko-fi खोलें"

msgid "Open Saweria"
msgstr "Saweria खोलें"

msgid "Open on GitHub"
msgstr "GitHub पर खोलें"

msgid "Press Escape on the lock screen to sleep display (or suspend)"
msgstr "स्क्रीन बंद करने (या निलंबित करने) के लिए लॉक स्क्रीन पर Esc दबाएं"

msgid "Prevent the screen from immediately turning off when locked. The screen will still turn off after the normal timeout duration set in system settings."
msgstr "लॉक होने पर स्क्रीन को तुरंत बंद होने से रोकें. स्क्रीन अभी भी सिस्टम सेटिंग्स में निर्धारित सामान्य समय के बाद बंद हो जाएगी."

msgid "Prompt Animation"
msgstr "पासवर्ड संकेत एनीमेशन"

msgid "Reset Animations"
msgstr "एनिमेशन रीसेट करें"

msgid "Reset animations"
msgstr "एनिमेशन रीसेट करें"

msgid "Resources"
msgstr "संसाधन"

msgid "Restore defaults"
msgstr "डिफॉल्ट्स का पुनःस्थापन"

msgid "Saweria"
msgstr "सवेरिया"

msgid "Show a custom message above the user prompt stack."
msgstr "उपयोगकर्ता संकेत के ऊपर एक कस्टम संदेश दिखाएं।"

msgid "Screen Timeout"
msgstr "स्क्रीन काल समापन"

msgid "Time to wait before turning off the screen"
msgstr "स्क्रीन बंद करने से पहले प्रतीक्षा समय"

msgid "Extras"
msgstr "अतिरिक्त"

msgid "[PRO] GDM Expansion"
msgstr "[PRO] GDM विस्तार"

msgid "Enabled. Custom layout is active on GDM."
msgstr "सक्षम। कस्टम लेआउट GDM पर सक्रिय है।"

msgid "Enabled"
msgstr "सक्षम"

msgid "Disabled"
msgstr "अक्षम"

msgid "Disabled."
msgstr "अक्षम।"

msgid "GDM and Cross Session Module are missing."
msgstr "GDM और क्रॉस सेशन मॉड्यूल गायब हैं।"

msgid "GDM dconf override configuration is missing."
msgstr "GDM dconf ओवरराइड कॉन्फ़िगरेशन गायब है।"

msgid "GDM integration is not configured."
msgstr "GDM एकीकरण कॉन्फ़िगर नहीं है।"

msgid "Upgrade to Pro"
msgstr "प्रो में अपग्रेड करें"

msgid "Get a Sonoma-inspired GDM login screen layout and automatically synchronize your wallpapers from the active user session. To upgrade, run copied command in a terminal."
msgstr "Sonoma-प्रेरित GDM लॉगिन स्क्रीन लेआउट प्राप्त करें और सक्रिय उपयोगकर्ता सत्र से अपने वॉलपेपर को स्वचालित रूप से सिंक्रनाइज़ करें। अपग्रेड करने के लिए, कॉपी किए गए कमांड को टर्मिनल में चलाएं।"

msgid "Copy upgrade command to clipboard"
msgstr "अपग्रेड कमांड को क्लिपबोर्ड पर कॉपी करें"

msgid "Copied upgrade command to clipboard!"
msgstr "अपग्रेड कमांड क्लिपबोर्ड पर कॉपी किया गया!"

msgid "Uninstall GDM Expansion"
msgstr "GDM विस्तार अनइंस्टॉल करें"

msgid "Revert GDM login screen layout to GNOME Default. To uninstall, run copied command in a terminal."
msgstr "GDM लॉगिन स्क्रीन लेआउट को GNOME डिफ़ॉल्ट पर वापस लाएं। अनइंस्टॉल करने के लिए, कॉपी किए गए कमांड को टर्मिनल में चलाएं।"

msgid "Copy uninstall command to clipboard"
msgstr "अनइंस्टॉल कमांड को क्लिपबोर्ड पर कॉपी करें"

msgid "Copied uninstall command to clipboard!"
msgstr "अनइंstॉल कमांड क्लिपबोर्ड पर कॉपी किया गया!"

msgid "[BETA] WACK Shell Integration"
msgstr "[BETA] WACK Shell एकीकरण"

msgid "Installed. Enables crossfade transitions and Cupertino-inspired shell customisations."
msgstr "स्थापित। क्रॉसफ़ेड संक्रमण और क्यूपर्टिनो-प्रेरित शेल अनुकूलन सक्षम करता है।"

msgid "Installed"
msgstr "स्थापित"

msgid "Not installed. Install WACK Shell to unlock transition effects."
msgstr "स्थापित नहीं है। संक्रमण प्रभावों को अनलॉक करने के लिए WACK Shell स्थापित करें।"

msgid "Not Installed"
msgstr "स्थापित नहीं"

msgid "Install WACK Shell"
msgstr "WACK Shell स्थापित करें"

msgid "Get advanced desktop crossfade transitions and Cupertino-inspired shell customisations. May contain bugs, report if found."
msgstr "उन्नत डेस्कटॉप क्रॉसफ़ेड संक्रमण और क्यूपर्टिनो-प्रेरित शेल अनुकूलन प्राप्त करें। इसमें बग हो सकते हैं, मिलने पर रिपोर्ट करें।"

msgid "Copy install command to clipboard"
msgstr "इंस्टॉल कमांड को क्लिपबोर्ड पर कॉपी करें"

msgid "Copied WACK Shell install command to clipboard!"
msgstr "WACK Shell इंस्टॉल कमांड क्लिपबोर्ड पर कॉपी किया गया!"

msgid "Open WACK Shell repository"
msgstr "WACK Shell रिपोजिटरी खोलें"

msgid "Check for Updates"
msgstr "अपडेट के लिए जाँच करें"

msgid "Copy check command to verify if a newer version of WACK Shell is available."
msgstr "WACK Shell का कोई नया संस्करण उपलब्ध है या नहीं, यह जाँचने के लिए जाँच कमांड कॉपी करें।"

msgid "Copy update-check command to clipboard"
msgstr "अपडेट-जाँच कमांड को क्लिपबोर्ड पर कॉपी करें"

msgid "Copied WACK Shell update-check command to clipboard!"
msgstr "WACK Shell अपडेट-जाँच कमांड क्लिपबोर्ड पर कॉपी किया गया!"

